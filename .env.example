# 数据库配置
DB_NAME=apple_order_mgr
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

# 邮件监听配置
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_email@qq.com
IMAP_PASSWORD=your_imap_password
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# 代理配置
PROXY_API_URL=https://api.kdlapi.com/api/getproxy
PROXY_API_KEY=your_proxy_key_here
PROXY_ENABLED=false

# 爬虫配置
CRAWLER_REQUEST_DELAY=5000
CRAWLER_MAX_RETRY=3
CRAWLER_TIMEOUT=30000
AUTO_ORDER_REFRESH_ENABLED=false
AUTO_ORDER_REFRESH_INTERVAL_MS=10000
CRAWLER_WIND_CONTROL_PAUSE_THRESHOLD=2

# Telegram 告警配置（仅使用占位符，生产环境从安全变量注入）
TELEGRAM_ENABLED=false
# 兼容旧变量名；新配置优先使用 TELEGRAM_ENABLED
TELEGRAM_ALERT_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_PROXY_URL=
TELEGRAM_TIMEOUT=10000
# 心跳配置预留：当前读取配置，用于后续心跳发送和静默窗口控制
TELEGRAM_HEARTBEAT_ENABLED=false
TELEGRAM_HEARTBEAT_INTERVAL_MS=300000
TELEGRAM_HEARTBEAT_QUIET_START=
TELEGRAM_HEARTBEAT_QUIET_END=

# 服务配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_DIR=./logs

# JWT 认证配置
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# 登录安全配置
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15

# Apple订单相关
APPLE_ORDER_BASE_URL=https://www.apple.com.cn/xc/cn/vieworder

# 测试配置（用于 test_crawler.js）
TEST_ORDER_NUMBER=W1234567890
TEST_APPLE_ID=test@example.com
