# 数据库配置
DB_NAME=apple_order_mgr
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

# 邮件监听配置
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_email@qq.com
IMAP_PASSWORD=your_imap_password
IMAP_TLS=true
IMAP_MAILBOX=INBOX

# 代理配置
PROXY_API_URL=https://api.kdlapi.com/api/getproxy
PROXY_API_KEY=your_proxy_key_here
PROXY_ENABLED=false

# 爬虫配置
CRAWLER_REQUEST_DELAY=5000
CRAWLER_MAX_RETRY=3
CRAWLER_TIMEOUT=30000

# 服务配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_DIR=./logs

# Apple订单相关
APPLE_ORDER_BASE_URL=https://www.apple.com.cn/xc/cn/vieworder

# 测试配置（用于 test_crawler.js）
TEST_ORDER_NUMBER=W1234567890
TEST_APPLE_ID=test@example.com
